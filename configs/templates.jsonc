    "check_run": {
      "payloads": [
        {
          "tags": [
            "completed",
            "success"
          ],
          "payload": {
            "msg_type": "interactive",
            "card": {
              "config": {
                "wide_screen_mode": true
              },
              "header": {
                "title": {
                  "tag": "plain_text",
                  "content": "✅ Check Succeeded: {{check_run.name}}"
                },
                "template": "green"
              },
              "elements": [
                {
                  "tag": "div",
                  "text": {
                    "tag": "lark_md",
                    "content": "**Repository:** {{repository_link_md | default('')}}\n**Check:** {{check_run.name}}\n**Status:** {{check_run.status}}\n**Conclusion:** {{check_run.conclusion}}\n"
                  }
                }
              ]
            }
          }
        },
        {
          "tags": [
            "completed",
            "failure"
          ],
          "payload": {
            "msg_type": "interactive",
            "card": {
              "config": {
                "wide_screen_mode": true
              },
              "header": {
                "title": {
                  "tag": "plain_text",
                  "content": "❌ Check Failed: {{check_run.name}}"
                },
                "template": "red"
              },
              "elements": [
                {
                  "tag": "div",
                  "text": {
                    "tag": "lark_md",
                    "content": "Repository:** {{repository_link_md | default('')}}\n**Check:** {{check_run.name}}\n****Status:** {{check_run.status}}\n**Conclusion:** {{check_run.conclusion}}\n"
                  }
                }
              ]
            }
          }
        },
        {
          "tags": [
            "default"
          ],
          "payload": {
            "msg_type": "interactive",
