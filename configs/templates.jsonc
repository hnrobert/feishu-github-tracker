// Template configuration file
// This file defines all Feishu message card templates for GitHub events (English version)
{
  "templates": {
    "branch_protection_configuration": {
      "payloads": [
        {
          "tags": [
            "disabled"
          ],
          "payload": {
            "msg_type": "interactive",
            "card": {
              "config": {
                "wide_screen_mode": true
              },
              "header": {
                "title": {
                  "tag": "plain_text",
                  "content": "🔔 Branch Protection Configuration Disabled"
                },
                "template": "turquoise"
              },
              "elements": [
                {
                  "tag": "div",
                  "text": {
                    "tag": "lark_md",
                    "content": "**Repository:** {{repository_link_md}}\n**Action:** {{action}}\n**User:** {{sender_link_md}}"
                  }
                },
                {
                  "tag": "hr"
                },
                {
                  "tag": "action",
                  "actions": [
                    {
                      "tag": "button",
                      "text": {
                        "tag": "plain_text",
                        "content": "View Details"
                      },
                      "url": "{{repository.html_url}}",
                      "type": "default"
                    }
                  ]
                }
              ]
            }
          }
        },
        {
          "tags": [
            "enabled"
          ],
          "payload": {
            "msg_type": "interactive",
            "card": {
              "config": {
                "wide_screen_mode": true
              },
              "header": {
                "title": {
                  "tag": "plain_text",
                  "content": "🔔 Branch Protection Configuration Enabled"
                },
                "template": "turquoise"
              },
              "elements": [
                {
                  "tag": "div",
                  "text": {
                    "tag": "lark_md",
                    "content": "**Repository:** {{repository_link_md}}\n**Action:** {{action}}\n**User:** {{sender_link_md}}"
                  }
                },
                {
                  "tag": "hr"
                },
                {
                  "tag": "action",
                  "actions": [
                    {
                      "tag": "button",
                      "text": {
                        "tag": "plain_text",
                        "content": "View Details"
                      },
                      "url": "{{repository.html_url}}",
                      "type": "default"
                    }
                  ]
                }
              ]
            }
          }
        }
      ]
    },
